<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#4CAF50"
            app:titleTextColor="@android:color/white" />

    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Source Language Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="From:"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#333333" />

            <Spinner
                android:id="@+id/spinner_source_lang"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@android:drawable/btn_dropdown" />

            <Button
                android:id="@+id/btn_detect_language"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Detect"
                android:textSize="12sp"
                android:layout_marginStart="8dp" />

        </LinearLayout>

        <TextView
            android:id="@+id/detected_lang_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="12sp"
            android:textColor="#4CAF50"
            android:layout_marginBottom="8dp" />

        <!-- Source Text -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@android:color/white"
            android:layout_marginBottom="8dp">

            <EditText
                android:id="@+id/edit_source_text"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="top"
                android:hint="Enter or write text to translate..."
                android:inputType="textMultiLine"
                android:padding="12dp"
                android:background="@android:color/transparent"
                android:textSize="16sp" />

        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btn_speak_source"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔊 Speak"
                style="@style/Widget.AppCompat.Button.Borderless" />

            <Button
                android:id="@+id/btn_swap_languages"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⇄ Swap"
                style="@style/Widget.AppCompat.Button.Borderless" />

        </LinearLayout>

        <!-- Target Language Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="To:"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#333333" />

            <Spinner
                android:id="@+id/spinner_target_lang"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@android:drawable/btn_dropdown" />

        </LinearLayout>

        <!-- Target Text -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@android:color/white"
            android:layout_marginBottom="8dp">

            <EditText
                android:id="@+id/edit_target_text"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="top"
                android:hint="Translation will appear here..."
                android:inputType="textMultiLine"
                android:padding="12dp"
                android:background="@android:color/transparent"
                android:textSize="16sp" />

        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btn_speak_target"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔊 Speak"
                style="@style/Widget.AppCompat.Button.Borderless" />

            <ProgressBar
                android:id="@+id/progress_translate"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:visibility="gone"
                android:layout_marginHorizontal="16dp" />

            <Button
                android:id="@+id/btn_translate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Translate"
                android:backgroundTint="#4CAF50" />

        </LinearLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
